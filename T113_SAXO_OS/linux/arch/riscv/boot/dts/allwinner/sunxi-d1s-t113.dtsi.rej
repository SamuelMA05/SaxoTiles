--- arch/riscv/boot/dts/allwinner/sunxi-d1s-t113.dtsi
+++ arch/riscv/boot/dts/allwinner/sunxi-d1s-t113.dtsi
@@ -143,6 +143,18 @@ uart3_pb_pins: uart3-pb-pins {
 				pins = "PB6", "PB7";
 				function = "uart3";
 			};
+
+			/omit-if-no-ref/
+			uart4_pg_pins: uart4-pg-pins {
+				pins = "PG2", "PG3";
+				function = "uart4";
+			};
+
+			/omit-if-no-ref/
+			uart5_pg_pins: uart5-pg-pins {
+				pins = "PG4", "PG5";
+				function = "uart5";
+			};		
 		};
 
 		ccu: clock-controller@2001000 {
